{
  "openapi": "3.0.3",
  "info": {
    "title": "NonPay API",
    "description": "NonPay Payment Processing API for collect (deposit) and disburse (withdrawal) operations",
    "version": "2.2.1"
  },
  "servers": [
    {
      "url": "https://api.nonpay.net",
      "description": "Production environment"
    },
    {
      "url": "https://api-test.nonpay.net",
      "description": "Test environment"
    }
  ],
  "paths": {
    "/wallet": {
      "get": {
        "tags": ["Account"],
        "summary": "Get Account Balance",
        "description": "Retrieve the current wallet balance for the authenticated merchant account",
        "operationId": "getWalletBalance",
        "parameters": [
          {
            "name": "sender_id",
            "in": "query",
            "description": "Unique merchant account identifier",
            "required": true,
            "schema": {
              "type": "string",
              "maxLength": 128
            },
            "example": "merchant_12345"
          }
        ],
        "responses": {
          "200": {
            "description": "Wallet balance retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "balance": {
                      "type": "string",
                      "description": "Current account balance",
                      "example": "5000.00"
                    },
                    "currency": {
                      "type": "string",
                      "description": "Currency code (ISO 4217)",
                      "example": "INR"
                    },
                    "sender_id": {
                      "type": "string",
                      "description": "Merchant account identifier"
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "date-time",
                      "description": "Timestamp of the balance query"
                    }
                  },
                  "required": ["balance", "currency", "sender_id", "timestamp"]
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid API credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ]
      }
    },
    "/submit": {
      "post": {
        "tags": ["Payments"],
        "summary": "Create Payment",
        "description": "Initiate a new payment transaction (collect or disburse)",
        "operationId": "createPayment",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PaymentCreateDTO"
              },
              "examples": {
                "CollectUPI": {
                  "summary": "Collect payment via UPI",
                  "value": {
                    "gross_amount": "100.00",
                    "callback": "https://merchant.com/callback",
                    "ccy": "INR",
                    "order_id": "order_20260331_001",
                    "side": "collect",
                    "flow": "peer",
                    "method": "upi",
                    "sender_id": "merchant_12345",
                    "sender_name": "Merchant Store",
                    "return_page": "https://merchant.com/success",
                    "headless": false,
                    "collect_details": {
                      "institution": "HDFC Bank",
                      "payer_full_name": "John Doe",
                      "upi_handle": "john.doe@ybl"
                    }
                  }
                },
                "CollectCard": {
                  "summary": "Collect payment via Card",
                  "value": {
                    "gross_amount": "250.50",
                    "callback": "https://merchant.com/callback",
                    "ccy": "INR",
                    "order_id": "order_20260331_002",
                    "side": "collect",
                    "flow": "card",
                    "method": "instant",
                    "sender_id": "merchant_12345",
                    "return_page": "https://merchant.com/success",
                    "headless": false,
                    "collect_details": {
                      "institution": "ICICI Bank",
                      "payer_full_name": "Jane Smith",
                      "card_details": {
                        "card_number": "4532123456789012",
                        "expiry_month": 12,
                        "expiry_year": 2028,
                        "cvv": "123",
                        "holder_name": "JANE SMITH"
                      }
                    }
                  }
                },
                "DisburseUPI": {
                  "summary": "Disburse payment via UPI",
                  "value": {
                    "gross_amount": "500.00",
                    "callback": "https://merchant.com/callback",
                    "ccy": "INR",
                    "order_id": "order_20260331_003",
                    "side": "disburse",
                    "flow": "peer",
                    "method": "imps",
                    "sender_id": "merchant_12345",
                    "sender_name": "Merchant Store",
                    "headless": true,
                    "disburse_details": {
                      "institution": "SBI Bank",
                      "receiver_name": "Alice Johnson",
                      "upi_handle": "alice.johnson@okaxis"
                    }
                  }
                },
                "DisburseCard": {
                  "summary": "Disburse payment via Card",
                  "value": {
                    "gross_amount": "1000.00",
                    "callback": "https://merchant.com/callback",
                    "ccy": "INR",
                    "order_id": "order_20260331_004",
                    "side": "disburse",
                    "flow": "card",
                    "method": "rapid",
                    "sender_id": "merchant_12345",
                    "sender_name": "Merchant Store",
                    "headless": true,
                    "disburse_details": {
                      "institution": "Axis Bank",
                      "receiver_name": "Bob Wilson",
                      "dest_card": "5412345678901234"
                    }
                  }
                },
                "DisburseIMPS": {
                  "summary": "Disburse payment via IMPS (Bank Transfer)",
                  "value": {
                    "gross_amount": "750.00",
                    "callback": "https://merchant.com/callback",
                    "ccy": "INR",
                    "order_id": "order_20260331_005",
                    "side": "disburse",
                    "flow": "peer",
                    "method": "imps",
                    "sender_id": "merchant_12345",
                    "sender_name": "Merchant Store",
                    "headless": true,
                    "disburse_details": {
                      "institution": "HDFC Bank",
                      "receiver_name": "Charlie Brown",
                      "account_no": "123456789012",
                      "routing_code": "HDFC0002060"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "transaction_id": {
                      "type": "string",
                      "description": "Unique transaction identifier"
                    },
                    "order_id": {
                      "type": "string",
                      "description": "Merchant order identifier"
                    },
                    "status": {
                      "type": "string",
                      "enum": ["pending", "processing", "success", "failed"],
                      "description": "Current transaction status"
                    },
                    "payment_url": {
                      "type": "string",
                      "format": "uri",
                      "description": "Payment page URL (for collect operations in non-headless mode)"
                    },
                    "gross_amount": {
                      "type": "string",
                      "description": "Payment amount"
                    },
                    "ccy": {
                      "type": "string",
                      "description": "Currency code"
                    },
                    "created_at": {
                      "type": "string",
                      "format": "date-time",
                      "description": "Payment creation timestamp"
                    }
                  },
                  "required": ["transaction_id", "order_id", "status"]
                },
                "examples": {
                  "SuccessCollect": {
                    "summary": "Successful collect payment",
                    "value": {
                      "transaction_id": "txn_abc123def456",
                      "order_id": "order_20260331_001",
                      "status": "pending",
                      "payment_url": "https://payment.nonpay.net/pay/txn_abc123def456",
                      "gross_amount": "100.00",
                      "ccy": "INR",
                      "created_at": "2026-03-31T23:48:00Z"
                    }
                  },
                  "SuccessDisburse": {
                    "summary": "Successful disburse payment",
                    "value": {
                      "transaction_id": "txn_xyz789uvw012",
                      "order_id": "order_20260331_003",
                      "status": "processing",
                      "gross_amount": "500.00",
                      "ccy": "INR",
                      "created_at": "2026-03-31T23:48:00Z"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "ValidationError": {
                    "value": {
                      "error": "VALIDATION_ERROR",
                      "message": "Invalid gross_amount format",
                      "timestamp": "2026-03-31T23:48:00Z"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid API credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error code"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp of the error"
          }
        },
        "required": ["error", "message"]
      },
      "CollectInfoDTO": {
        "type": "object",
        "description": "Collect (deposit) credentials",
        "properties": {
          "institution": {
            "type": "string",
            "maxLength": 128,
            "description": "Financial institution name"
          },
          "payer_full_name": {
            "type": "string",
            "maxLength": 128,
            "description": "Full name of the payer"
          },
          "card_details": {
            "$ref": "#/components/schemas/PaymentCardInfo"
          },
          "upi_handle": {
            "type": "string",
            "pattern": "^[a-z0-9-_.]{1,128}@[a-z0-9]{1,128}$",
            "description": "UPI handle in format name@bank (e.g., user@ybl)"
          }
        }
      },
      "DisburseInfoDTO": {
        "type": "object",
        "description": "Disburse (withdrawal) credentials",
        "properties": {
          "institution": {
            "type": "string",
            "description": "Financial institution name"
          },
          "dest_card": {
            "type": "string",
            "description": "Destination card number (credit/debit card)"
          },
          "receiver_name": {
            "type": "string",
            "maxLength": 256,
            "description": "Receiver name (required for card, IMPS, or UPI disbursements)"
          },
          "routing_code": {
            "type": "string",
            "pattern": "^[a-z]{4}0[a-z0-9]{6}$",
            "description": "Routing code in format XXXX0XXXXXX (e.g., HDFC0002060). Required for IMPS."
          },
          "account_no": {
            "type": "string",
            "minLength": 9,
            "maxLength": 32,
            "description": "Bank account number"
          },
          "upi_handle": {
            "type": "string",
            "pattern": "^[a-z0-9-_.]{1,128}@[a-z0-9]{1,128}$",
            "description": "UPI handle in format name@bank (e.g., user@ybl)"
          },
          "intl_account": {
            "type": "string",
            "description": "International account identifier (IBAN)"
          },
          "tin": {
            "type": "string",
            "description": "Tax Identification Number"
          }
        }
      },
      "PaymentCardInfo": {
        "type": "object",
        "description": "Payment card information",
        "properties": {
          "card_number": {
            "type": "string",
            "description": "Card number (will be validated as credit card)"
          },
          "expiry_month": {
            "type": "integer",
            "minimum": 1,
            "maximum": 12,
            "description": "Card expiry month"
          },
          "expiry_year": {
            "type": "integer",
            "description": "Card expiry year (2-digit or 4-digit)"
          },
          "cvv": {
            "type": "string",
            "minLength": 3,
            "maxLength": 4,
            "description": "Card CVV/CVC code"
          },
          "holder_name": {
            "type": "string",
            "description": "Cardholder name"
          }
        }
      },
      "PaymentCreateDTO": {
        "type": "object",
        "description": "Payment creation request",
        "required": [
          "gross_amount",
          "callback",
          "ccy",
          "order_id",
          "side",
          "flow",
          "sender_id"
        ],
        "properties": {
          "gross_amount": {
            "type": "string",
            "pattern": "^\\d+(\\.\\d{1,2})?$",
            "description": "Payment amount (money format)"
          },
          "callback": {
            "type": "string",
            "format": "uri",
            "description": "Callback URL for payment status notifications"
          },
          "ccy": {
            "type": "string",
            "pattern": "^[A-Z]{3}$",
            "description": "Currency code (ISO 4217, e.g., INR, USD)"
          },
          "order_id": {
            "type": "string",
            "minLength": 5,
            "maxLength": 64,
            "description": "Unique order identifier from merchant"
          },
          "side": {
            "type": "string",
            "enum": ["collect", "disburse"],
            "description": "Transaction direction: collect (deposit) or disburse (withdrawal)"
          },
          "flow": {
            "type": "string",
            "enum": ["peer", "card"],
            "description": "Payment flow type"
          },
          "method": {
            "type": "string",
            "enum": ["upi", "upi_intent", "imps", "instant", "rapid"],
            "description": "Payment method (optional)"
          },
          "sender_id": {
            "type": "string",
            "maxLength": 128,
            "description": "Merchant account identifier"
          },
          "sender_name": {
            "type": "string",
            "maxLength": 128,
            "description": "Merchant account name (optional)"
          },
          "return_page": {
            "type": "string",
            "format": "uri",
            "description": "Return page URL for collect operations in non-headless mode. Required if headless is false and side is 'collect'"
          },
          "headless": {
            "type": "boolean",
            "description": "Whether to operate in headless mode (no redirect to payment page)"
          },
          "collect_details": {
            "$ref": "#/components/schemas/CollectInfoDTO"
          },
          "disburse_details": {
            "$ref": "#/components/schemas/DisburseInfoDTO"
          },
          "traffic_type": {
            "type": "string",
            "description": "Traffic classification (optional)"
          }
        }
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT token in format: Bearer <token>"
      }
    }
  },
  "tags": [
    {
      "name": "Account",
      "description": "Account and balance operations"
    },
    {
      "name": "Payments",
      "description": "Payment transaction operations"
    }
  ]
}
