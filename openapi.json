                      "type": "string",
                      "format": "uuid",
                      "description": "Unique transaction identifier"
                    },
                    "order_id": {
                      "type": "string",
                      "description": "Merchant order identifier"
                    },
                    "state": {
                      "type": "string",
                      "enum": ["in_progress", "completed", "failed", "rejected", "paid_adjusted", "paid_partial"],
                      "description": "Current transaction state"
                    },
                    "method": {
                      "type": "string",
                      "description": "Payment method used (UPI, IMPS, etc.)"
                    },
                    "payment_link": {
                      "type": "string",
                      "format": "uri",
